@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="min-h-dvh flex flex-col bg-slate-900 text-white antialiased">
    <header class="bg-slate-900 border-b border-slate-800 sticky top-0 z-10">
        <div class="max-w-md mx-auto px-4 py-3 flex items-center justify-between gap-3">
            <a href="/site/today" class="flex items-center gap-2 font-semibold shrink-0">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-white text-slate-900 text-xs">JP</span>
                <span>JPMS Site</span>
            </a>
            @if (Auth.IsSignedIn)
            {
                <button class="text-xs font-medium text-slate-300 hover:text-white underline underline-offset-4"
                        @onclick="SignOut">
                    Sign out
                </button>
            }
        </div>
    </header>

    <main class="flex-1 bg-slate-50 text-slate-900">
        @Body
    </main>

    <footer class="bg-slate-900 border-t border-slate-800">
        <div class="max-w-md mx-auto px-4 py-3 text-xs text-slate-400 flex items-center justify-between">
            <span>Field app</span>
            <a href="/dashboard" class="hover:text-white underline underline-offset-4">Desktop</a>
        </div>
    </footer>
</div>

@code {
    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;

    private void SignOut() => Nav.NavigateTo("/logout", forceLoad: true);

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}

@inherits LayoutComponentBase
@inject AuthService Auth
@inject SessionService Session
@implements IDisposable

<div class="min-h-dvh bg-canvas text-content antialiased">

    @if (CanSeeNavigation)
    {
        <aside class="@SideNavClass">
            <SideNav IsExpanded="isSideNavExpanded" OnToggleExpand="ToggleSideNav" />
        </aside>
    }

    <div class="@ShellClass">
        <header class="sticky top-0 z-30 h-14 bg-canvas/80 backdrop-blur border-b border-line">
            <div class="h-full px-4 flex items-center justify-between gap-3">
                @if (CanSeeNavigation)
                {
                    <PageHeading />
                }
                else
                {
                    <span></span>
                }
                @if (Auth.IsSignedIn)
                {
                    <RoleSwitcher />
                }
                else
                {
                    <span class="eyebrow">Jewel Project Management System</span>
                }
            </div>
        </header>

        <main class="flex-1">
            @Body
        </main>

        <footer class="border-t border-line">
            <div class="px-4 py-3 text-xs text-content-subtle flex items-center justify-between">
                <span>Jewel Enterprises</span>
                <span>JPMS v0.1</span>
            </div>
        </footer>
    </div>
</div>

@code {
    private bool isSideNavExpanded = true;

    private bool CanSeeNavigation => Auth.IsSignedIn && Session.IsApproved;

    private string SideNavClass
    {
        get
        {
            var width = isSideNavExpanded ? "md:w-64" : "md:w-16";
            return $"fixed top-0 bottom-0 left-0 z-40 w-16 {width} border-r border-line";
        }
    }

    private string ShellClass
    {
        get
        {
            var column = "min-h-dvh flex flex-col";
            if (!CanSeeNavigation) return column;
            var padding = isSideNavExpanded ? "pl-16 md:pl-64" : "pl-16 md:pl-16";
            return $"{column} {padding}";
        }
    }

    protected override void OnInitialized()
    {
        Auth.OnChange += StateHasChanged;
        Session.OnChange += StateHasChanged;
    }

    private void ToggleSideNav() => isSideNavExpanded = !isSideNavExpanded;

    public void Dispose()
    {
        Auth.OnChange -= StateHasChanged;
        Session.OnChange -= StateHasChanged;
    }
}

@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="min-h-dvh flex flex-col bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white sticky top-0 z-10">
        <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
            <a href="@(Auth.IsSignedIn ? "/dashboard" : "/")" class="flex items-center gap-2 font-semibold text-slate-900">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-slate-900 text-white text-xs">JP</span>
                <span>JPMS</span>
            </a>

            @if (Auth.IsSignedIn)
            {
                <div class="flex items-center gap-3">
                    <span class="hidden sm:inline text-xs text-slate-500">@Auth.CurrentUser!.Email</span>
                    <button class="text-xs font-medium text-slate-700 hover:text-slate-900 underline underline-offset-4"
                            @onclick="HandleSignOut">
                        Sign out
                    </button>
                </div>
            }
            else
            {
                <span class="text-[11px] uppercase tracking-wider text-slate-500 font-medium">Jewel Project Management System</span>
            }
        </div>
    </header>

    <main class="flex-1">
        @Body
    </main>

    <footer class="border-t border-slate-200 bg-white">
        <div class="max-w-3xl mx-auto px-4 py-3 text-xs text-slate-500 flex items-center justify-between">
            <span>Jewel Enterprises</span>
            <span>JPMS v0.1</span>
        </div>
    </footer>
</div>

@code {
    protected override void OnInitialized()
    {
        Auth.OnChange += StateHasChanged;
    }

    private async Task HandleSignOut()
    {
        await Auth.SignOutAsync();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Auth.OnChange -= StateHasChanged;
    }
}

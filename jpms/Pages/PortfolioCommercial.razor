@page "/portfolio/commercial"
@inject AuthService Auth
@inject SessionService Session
@inject IProjectStore ProjectStore
@inject ICvrStore CvrStore
@inject NavigationManager Nav

<PageTitle>Portfolio commercial · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/portfolio" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Portfolio</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">Commercial</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Commercial portfolio</h1>
            <p class="text-sm text-slate-600 mt-1">Margin actual vs forecast across every active project.</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 mb-6">
            <Stat Label="Tender total"      Value="@Money(TenderTotal)" />
            <Stat Label="Forecast margin"   Value="@Money(MarginTotal)" />
            <Stat Label="Portfolio margin"  Value="@($"{PortfolioMarginPercent:0.0}%")" />
        </div>

        <PortfolioMarginTable Projects="ProjectStore.All()" />
    </section>
}

@code {
    private bool isLoaded;

    private decimal TenderTotal =>
        ProjectStore.All().Sum(p => CvrStore.LatestSnapshot(p.ProjectId)?.TenderValue ?? 0);
    private decimal MarginTotal =>
        ProjectStore.All().Sum(p => CvrStore.LatestSnapshot(p.ProjectId)?.MarginPounds ?? 0);
    private decimal PortfolioMarginPercent =>
        TenderTotal == 0 ? 0 : (MarginTotal / TenderTotal) * 100m;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}

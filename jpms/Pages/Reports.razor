@page "/reports"
@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Reports · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">JPMS · Finance</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Reports</h1>
            <p class="text-sm text-slate-600 mt-2">
                Downloadable CSVs for the accountancy back-office. Direct Xero integration is a later phase.
            </p>
        </header>

        <nav class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-200">
            <PortalNavLink Href="/reports/valuations"  Label="Approved valuations" Detail="Programme Valuation Report per period — CSV export for Xero AR" />
            <PortalNavLink Href="/reports/timesheets"  Label="Approved timesheets" Detail="Day-rate hours per cost code — CSV export for payroll" />
        </nav>
    </section>
}

@code {
    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }
}

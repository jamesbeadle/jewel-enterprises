@page "/dashboard"
@inject AuthService Auth
@inject IUserDirectory UserDirectory
@inject NavigationManager Nav

<PageTitle>Dashboard · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-3xl mx-auto px-4 py-12 text-slate-500 text-sm">
        Loading your dashboard…
    </section>
}
else if (directoryUser is null)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (directoryUser.Role.IsAdministrative())
{
    <AdminHome CurrentUser="Auth.CurrentUser!" />
}
else
{
    <PlaceholderHome User="directoryUser" Provider="Auth.CurrentUser!.Provider" />
}

@code {
    private bool isLoaded;
    private DirectoryUser? directoryUser;

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureInitialisedAsync();
        if (!Auth.IsSignedIn)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }
        directoryUser = UserDirectory.Find(Auth.CurrentUser!.Email);
        isLoaded = true;
    }
}

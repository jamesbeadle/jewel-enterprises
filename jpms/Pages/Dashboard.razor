@page "/dashboard"
@inject AuthService Auth
@inject IUserDirectory UserDirectory
@inject SessionService Session
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Dashboard · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-3xl mx-auto px-4 py-12 text-slate-500 text-sm">
        Loading your dashboard…
    </section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (Session.ActiveRole == Role.Admin)
{
    <AdminHome CurrentUser="Auth.CurrentUser!" />
}
else if (Session.ActiveRole is not null)
{
    <PlaceholderHome
        Role="Session.ActiveRole.Value"
        DisplayName="@Auth.CurrentUser!.DisplayName"
        Email="@Auth.CurrentUser.Email" />
}

@code {
    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureInitialisedAsync();
        if (!Auth.IsSignedIn)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        var email = Auth.CurrentUser!.Email;
        var directoryEntry = UserDirectory.Find(email);
        var roles = EffectiveRoles.For(email, directoryEntry);
        var displayName = string.IsNullOrWhiteSpace(directoryEntry?.DisplayName)
            ? Auth.CurrentUser.DisplayName
            : directoryEntry!.DisplayName;
        var sessionUser = Auth.CurrentUser with { DisplayName = displayName };
        Session.Adopt(sessionUser, roles);
        Session.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => Session.OnChange -= StateHasChanged;
}

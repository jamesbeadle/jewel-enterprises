@page "/projects/{ProjectId}/drawings/ambiguous"
@inject AuthService Auth
@inject SessionService Session
@inject IDrawingStore DrawingStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Ambiguous revisions · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="drawings">
        <nav class="mb-4 text-sm">
            <a href="@($"/projects/{ProjectId}/drawings")" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Drawings</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">Ambiguous queue</span>
        </nav>

        <h2 class="text-lg font-semibold text-slate-900 mb-3">Revisions JPMS couldn't auto-classify</h2>
        <p class="text-sm text-slate-600 mb-5">
            These uploads had filenames that didn't match the expected revision pattern. PM action required.
        </p>

        @if (Ambiguous.Count == 0)
        {
            <p class="text-sm text-slate-500 italic">Nothing pending classification.</p>
        }
        else
        {
            <DrawingRevisionList Revisions="Ambiguous" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    private IReadOnlyList<DrawingRevision> Ambiguous => DrawingStore.AmbiguousFor(ProjectId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        DrawingStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => DrawingStore.OnChange -= StateHasChanged;
}

<div class="rounded-xl border border-slate-200 bg-white overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Worked on</th>
                <th class="px-4 py-3">Subcontractor</th>
                <th class="px-4 py-3">Description</th>
                <th class="px-4 py-3 text-right">Total cost</th>
                <th class="px-4 py-3 text-right">Chargeable</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var daywork in Dayworks)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-700">@daywork.WorkedOn.LocalDateTime.ToString("d MMM yyyy")</td>
                    <td class="px-4 py-3 text-slate-900 font-medium">@daywork.SubcontractorReference</td>
                    <td class="px-4 py-3 text-slate-700">@daywork.Description</td>
                    <td class="px-4 py-3 text-right text-slate-700">@Money(daywork.TotalCost)</td>
                    <td class="px-4 py-3 text-right text-slate-900 font-medium">@Money(daywork.ChargeableAmount)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Daywork> Dayworks { get; set; } = Array.Empty<Daywork>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}

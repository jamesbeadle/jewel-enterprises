@inject IUserDirectory UserDirectory

<li class="px-5 py-3 flex items-center justify-between gap-4">
    <div class="min-w-0">
        <p class="text-slate-900 font-medium leading-snug truncate">@User.DisplayName</p>
        <p class="text-sm text-slate-600 break-all">@User.Email</p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
        <div class="flex flex-wrap items-center gap-1 justify-end">
            @foreach (var role in DisplayedRoles)
            {
                <RoleBadge Role="role" />
            }
        </div>
        @if (IsCurrentUser)
        {
            <span class="text-[11px] text-slate-400" title="You can't revoke your own access here.">You</span>
        }
        else
        {
            <button type="button" @onclick="Revoke"
                    class="text-xs font-medium text-slate-500 hover:text-rose-700 underline underline-offset-4">
                Revoke
            </button>
        }
    </div>
</li>

@code {
    [Parameter, EditorRequired] public DirectoryUser User { get; set; } = default!;
    [Parameter] public bool IsCurrentUser { get; set; }

    private IEnumerable<Role> DisplayedRoles
    {
        get
        {
            if (JpmsAdministrators.Contains(User.Email)) yield return Role.Admin;
            foreach (var role in User.Roles)
            {
                if (role == Role.Admin && JpmsAdministrators.Contains(User.Email)) continue;
                yield return role;
            }
        }
    }

    private void Revoke() => UserDirectory.Remove(User.Email);
}

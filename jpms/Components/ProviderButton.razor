@using Jewel.JPMS.Components.Icons

<button type="button"
        @onclick="OnClick"
        class="w-full inline-flex items-center justify-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-800 font-medium hover:border-slate-300 hover:shadow-sm transition focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-900 focus-visible:ring-offset-2">
    <span class="w-5 h-5 shrink-0 inline-flex items-center justify-center">
        @if (Provider == AuthProvider.Microsoft)
        {
            <MicrosoftLogoIcon />
        }
        else
        {
            <GoogleLogoIcon />
        }
    </span>
    <span>Continue with @ProviderName</span>
</button>

@code {
    [Parameter, EditorRequired] public AuthProvider Provider { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private string ProviderName => Provider switch
    {
        AuthProvider.Microsoft => "Microsoft",
        AuthProvider.Google    => "Google",
        _ => Provider.ToString()
    };
}

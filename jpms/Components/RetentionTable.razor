<div class="rounded-xl border border-slate-200 bg-white overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Subcontractor</th>
                <th class="px-4 py-3 text-right">Certified</th>
                <th class="px-4 py-3 text-right">Retention held</th>
                <th class="px-4 py-3 text-right">Balance held</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var retention in Retentions)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium">@retention.SubcontractorReference</td>
                    <td class="px-4 py-3 text-right text-slate-700">@Money(retention.CertifiedAmount)</td>
                    <td class="px-4 py-3 text-right text-slate-700">@Money(retention.RetentionAmount)</td>
                    <td class="px-4 py-3 text-right text-slate-900 font-medium">@Money(retention.BalanceHeld)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<SubcontractorRetention> Retentions { get; set; } = Array.Empty<SubcontractorRetention>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}

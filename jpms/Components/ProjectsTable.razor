@inject NavigationManager Nav

<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Reference</th>
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3 hidden md:table-cell">Client</th>
                <th class="px-4 py-3 hidden lg:table-cell">Entity</th>
                <th class="px-4 py-3">Stage</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var project in Projects)
            {
                <tr class="hover:bg-slate-50 cursor-pointer transition"
                    @onclick="() => OpenProject(project.ProjectId)">
                    <td class="px-4 py-3 font-mono text-xs text-slate-700">@project.Reference</td>
                    <td class="px-4 py-3 text-slate-900 font-medium">@project.Name</td>
                    <td class="px-4 py-3 text-slate-600 hidden md:table-cell">@project.ClientName</td>
                    <td class="px-4 py-3 text-slate-600 hidden lg:table-cell">@project.Organisation.ShortCode()</td>
                    <td class="px-4 py-3"><ProjectStageBadge Stage="project.Stage" /></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Project> Projects { get; set; } = Array.Empty<Project>();

    private void OpenProject(string projectId) =>
        Nav.NavigateTo($"/projects/{projectId}");
}

@inject IAccessRequestStore Requests

<section class="rounded-xl border border-slate-200 bg-white overflow-hidden mb-6">
    <header class="px-5 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
        <h2 class="text-sm font-medium text-slate-700">Pending access requests</h2>
        <span class="text-xs text-slate-500">@PendingRequests.Count</span>
    </header>

    @if (PendingRequests.Count == 0)
    {
        <div class="p-5">
            <p class="text-slate-500 italic text-sm">
                No pending requests. New requests appear here when a signed-in user clicks <em>Request access</em>.
            </p>
        </div>
    }
    else
    {
        <ul class="divide-y divide-slate-200">
            @foreach (var request in PendingRequests)
            {
                <PendingRequestRow Request="request" />
            }
        </ul>
    }
</section>

@code {
    private IReadOnlyList<AccessRequest> PendingRequests => Requests.Pending();
}

%% Workflow: Lead to Won Deal — cross-actor view
%% Companion to docs/user-journeys/01-onboarding-sales-lead.md
%% Worked example — replace with real process during discovery.

flowchart TD
    A([Lead created]) --> B{Existing\ncustomer match?}
    B -- Yes --> M[Merge flow]
    B -- No --> C[Sales Rep qualifies lead]
    M --> C
    C --> D{Score >= 50?}
    D -- No --> N[Nurture cadence]
    D -- Yes --> E[Create Opportunity]
    E --> F[Sales Manager review]
    F --> G[Draft quote]
    G --> H{Quote above\napproval threshold?}
    H -- Yes --> I[Business Owner approves]
    H -- No --> J[Send to customer]
    I --> J
    J --> K{Won or Lost?}
    K -- Lost --> L([Archive with reason])
    K -- Won --> O[Create Customer & Project]
    O --> P[Notify Finance for billing]
    P --> Q([Handover to Project Kickoff])

    classDef actor fill:#eef,stroke:#446,stroke-width:1px;
    classDef system fill:#efe,stroke:#464,stroke-width:1px;
    classDef terminal fill:#ffe,stroke:#664,stroke-width:1px;
    class A,L,Q terminal;

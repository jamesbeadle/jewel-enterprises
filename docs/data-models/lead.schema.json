{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jewelgroup.co.uk/schemas/lead.schema.json",
  "title": "Lead",
  "description": "A potential customer enquiry, before qualification. Referenced from docs/user-journeys/01-onboarding-sales-lead.md. Worked example — confirm fields and constraints during the on-site role-play session.",
  "type": "object",
  "required": [
    "id",
    "contactName",
    "companyName",
    "email",
    "source",
    "status",
    "ownerId",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^lead_[A-Z0-9]{20,}$",
      "description": "Prefixed ULID."
    },
    "contactName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "companyName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 254
    },
    "phone": {
      "type": "string",
      "pattern": "^\\+[1-9]\\d{6,14}$",
      "description": "E.164 format. Optional."
    },
    "source": {
      "type": "string",
      "enum": ["Web", "Phone", "Referral", "Event", "Other"]
    },
    "status": {
      "type": "string",
      "enum": ["New", "Qualified", "Nurture", "Disqualified", "Converted"]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Auto-calculated from qualification fields. Rule set to be confirmed."
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "budgetRange": {
          "type": "string",
          "enum": ["<10k", "10-50k", "50-250k", "250k+", "Unknown"]
        },
        "timeframe": {
          "type": "string",
          "enum": ["0-3m", "3-6m", "6-12m", ">12m"]
        },
        "decisionMaker": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "ownerId": {
      "type": "string",
      "description": "User ID of the Sales Rep who owns this lead."
    },
    "customerId": {
      "type": ["string", "null"],
      "description": "Populated once the lead converts to an existing Customer."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
